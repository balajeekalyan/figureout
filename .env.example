# API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
META_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# FigureOut Settings (required)
FIGUREOUT_LLM=                      # openai | gemini | claude | meta | mistral | groq
FIGUREOUT_LLM_VERSION=              # e.g. gpt-4o, gemini-2.0-flash, claude-sonnet-4-20250514

# FigureOut Settings (optional)
FIGUREOUT_LITE_LLM_VERSION=         # cheaper model for classification; defaults to FIGUREOUT_LLM_VERSION
FIGUREOUT_ROLES=                    # JSON role registry (alternative to passing roles= in constructor)
FIGUREOUT_VERBOSE=false
FIGUREOUT_MAX_ROLES=1
FIGUREOUT_MAX_OUTPUT_TOKENS=16384
FIGUREOUT_MAX_RETRIES=2
FIGUREOUT_TIMEOUT=120                # request timeout in seconds
FIGUREOUT_INTERPRET_TOOL_RESPONSE=true
FIGUREOUT_CACHE_ENABLED=true
FIGUREOUT_CACHE_SIZE=128
FIGUREOUT_MAX_TOOL_ROUNDS=3
